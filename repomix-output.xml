    align-items: center;
    flex-wrap: wrap;
  }

  header .logo {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  header .logo span {
    color: var(--azul-claro);
  }

  header nav a {
    color: var(--branco);
    margin-left: 1.5rem;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  header nav a:hover {
    color: var(--azul-claro);
  }

  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(135deg, var(--azul-escuro) 0%, var(--azul-royal) 100%);
    color: var(--branco);
    text-align: center;
    padding: 5rem 1.5rem;
  }

  .hero h1 {
    font-size: 2.6rem;
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .hero p {
    font-size: 1.15rem;
    max-width: 640px;
    margin: 0 auto 2rem auto;
    color: var(--azul-claro);
  }

  .btn-cta {
    display: inline-block;
    background-color: var(--azul-medio);
    color: var(--branco);
    padding: 0.9rem 2.2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1.05rem;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;
  }

  .btn-cta:hover {
    background-color: var(--azul-royal);
    transform: translateY(-2px);
  }

  /* ===== SERVIÇOS ===== */
  .servicos {
